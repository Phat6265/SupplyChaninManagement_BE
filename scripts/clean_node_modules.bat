
@echo off
echo Cleaning node_modules for BE and FE...

echo ========================================
echo Removing BE node_modules...
cd /d "%~dp0\.."
if exist "node_modules" (
    rmdir /s /q "node_modules"
    echo - Deleted BE node_modules successfully.
) else (
    echo - BE node_modules does not exist.
)

echo ========================================
echo Removing FE node_modules...
cd /d "%~dp0\..\..\SupplyChaninManagement_FE"
if exist "node_modules" (
    rmdir /s /q "node_modules"
    echo - Deleted FE node_modules successfully.
) else (
    echo - FE node_modules does not exist.
)

echo ========================================
echo Done!
pause
